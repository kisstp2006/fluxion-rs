// ============================================================
// assets.rn — Asset Browser panel
//
// Lists files in the project assets/ directory, grouped by
// subdirectory.  Clicking a .fluxscene file loads the scene.
// ============================================================

pub mod assets {

fn file_icon(name) {
    // name is passed by value; .ends_with() snapshots it — use clone between calls.
    if name.clone().ends_with(".fluxscene") { return "[SCN]"; }
    if name.clone().ends_with(".obj") || name.clone().ends_with(".gltf") || name.clone().ends_with(".glb") { return "[MDL]"; }
    if name.clone().ends_with(".png") || name.clone().ends_with(".jpg") || name.clone().ends_with(".jpeg") || name.clone().ends_with(".webp") { return "[TEX]"; }
    if name.clone().ends_with(".rn")  { return " [RN]"; }
    if name.clone().ends_with(".wav") || name.clone().ends_with(".ogg") || name.clone().ends_with(".mp3")  { return "[SND]"; }
    "[   ]"
}

pub fn panel() {
    fluxion::ui::label("Assets");
    fluxion::ui::separator();

    // Root-level files
    let root_files = fluxion::world::list_assets("");
    if root_files.len() > 0 {
        if fluxion::ui::collapsing_begin("/ (root)") {
            let i = 0;
            while i < root_files.len() {
                let f    = root_files[i].clone();
                let icon = file_icon(f.clone());
                fluxion::ui::label(`${icon} ${f}`);
                i += 1;
            }
            fluxion::ui::collapsing_end();
        }
    }

    // Subdirectories
    let dirs = fluxion::world::list_asset_dirs();
    let di = 0;
    while di < dirs.len() {
        let dir = dirs[di].clone();
        if fluxion::ui::collapsing_begin(dir.clone()) {
            let files = fluxion::world::list_assets(dir.clone());
            let fi = 0;
            while fi < files.len() {
                let f     = files[fi].clone();
                let icon  = file_icon(f.clone());
                let label = `${icon} ${f}`;
                if fluxion::ui::button(label) {
                    if f.clone().ends_with(".fluxscene") {
                        fluxion::world::log(`[Assets] Load scene: ${dir}/${f}`);
                    }
                }
                fi += 1;
            }
            if files.is_empty() {
                fluxion::ui::small("(empty)");
            }
            fluxion::ui::collapsing_end();
        }
        di += 1;
    }

    if dirs.is_empty() && root_files.is_empty() {
        fluxion::ui::small("(no assets found)");
    }
}

} // pub mod assets
