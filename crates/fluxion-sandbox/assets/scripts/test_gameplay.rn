// ============================================================
// test_gameplay.rn — Example gameplay script (new Unity-style API)
//
// Demonstrates the prelude-based OOP API:
//   self_transform() / self_gameobject()
//   Transform::rotate / translate / position
//   Input::get_key / get_axis using Key constants
//   Time::frame_count / Debug::log
//
// Inspector fields come from the TestGameplay struct below.
// ============================================================

struct TestGameplay {
    rotate_speed,
    move_speed,
    jump_key,
}

impl TestGameplay {
    pub fn new() {
        TestGameplay {
            rotate_speed: 90.0,
            move_speed: 5.0,
            jump_key: 0.0,
        }
    }
}

pub fn start() {
    let go = self_gameobject();
    Debug::log(`[TestScript] start() — entity: ${go.name()}`);
}

pub fn update(dt) {
    let transform = self_transform();

    // ── Rotation (Y axis, degrees per second) ────────────────────────────────
    // rotate() takes degree deltas — no read-modify-write needed.
    transform.rotate(0.0, 90.0 * dt, 0.0);

    // ── WASD Movement ────────────────────────────────────────────────────────
    let h = Input::get_axis(Key::A(), Key::D());
    let v = Input::get_axis(Key::S(), Key::W());

    let move_speed = 5.0;
    let delta = Vec3 { x: h * move_speed * dt, y: 0.0, z: v * move_speed * dt };
    transform.translate(delta);

    // ── Sprint (hold Shift for 2x speed) ─────────────────────────────────────
    let sprint = if Input::get_key(Key::LeftShift()) { 2.0 } else { 1.0 };

    // ── Jump on Space (just-pressed) ──────────────────────────────────────────
    if Input::get_key_down(Key::Space()) {
        Debug::log("[TestScript] Jump!");
    }

    // ── Debug output every 60 frames ─────────────────────────────────────────
    let frame = Time::frame_count();
    if frame % 60 == 0 {
        let pos = transform.position();
        Debug::log(`[TestScript] frame=${frame}  pos=(${pos.x:.2}, ${pos.y:.2}, ${pos.z:.2})`);
    }
}

pub fn on_destroy() {
    Debug::log("[TestScript] on_destroy() called");
}
