    pub fn N() { "KeyN" }
    pub fn O() { "KeyO" }
    pub fn P() { "KeyP" }
    pub fn Q() { "KeyQ" }
    pub fn R() { "KeyR" }
    pub fn S() { "KeyS" }
    pub fn T() { "KeyT" }
    pub fn U() { "KeyU" }
    pub fn V() { "KeyV" }
    pub fn W() { "KeyW" }
    pub fn X() { "KeyX" }
    pub fn Y() { "KeyY" }
    pub fn Z() { "KeyZ" }

    // Digits
    pub fn Alpha0() { "Digit0" }
    pub fn Alpha1() { "Digit1" }
    pub fn Alpha2() { "Digit2" }
    pub fn Alpha3() { "Digit3" }
    pub fn Alpha4() { "Digit4" }
