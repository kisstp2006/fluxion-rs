    pub fn Alpha6() { "Digit6" }
    pub fn Alpha7() { "Digit7" }
    pub fn Alpha8() { "Digit8" }
    pub fn Alpha9() { "Digit9" }

    // Special keys
    pub fn Space()     { "Space" }
    pub fn Return()    { "Enter" }
    pub fn Escape()    { "Escape" }
    pub fn Tab()       { "Tab" }
    pub fn Backspace() { "Backspace" }
    pub fn Delete()    { "Delete" }
    pub fn Insert()    { "Insert" }
    pub fn Home()      { "Home" }
    pub fn End()       { "End" }
    pub fn PageUp()    { "PageUp" }
    pub fn PageDown()  { "PageDown" }

    // Modifier keys
    pub fn LeftShift()  { "ShiftLeft" }
    pub fn RightShift() { "ShiftRight" }
    pub fn LeftCtrl()   { "ControlLeft" }
    pub fn RightCtrl()  { "ControlRight" }
    pub fn LeftAlt()    { "AltLeft" }
    pub fn RightAlt()   { "AltRight" }

    // Arrow keys
    pub fn Left()  { "ArrowLeft" }
    pub fn Right() { "ArrowRight" }
    pub fn Up()    { "ArrowUp" }
    pub fn Down()  { "ArrowDown" }

    // Function keys
    pub fn F1()  { "F1" }
    pub fn F2()  { "F2" }
    pub fn F3()  { "F3" }
    pub fn F4()  { "F4" }
    pub fn F5()  { "F5" }
    pub fn F6()  { "F6" }
    pub fn F7()  { "F7" }
    pub fn F8()  { "F8" }
    pub fn F9()  { "F9" }
    pub fn F10() { "F10" }
    pub fn F11() { "F11" }
    pub fn F12() { "F12" }

    // Mouse buttons
    pub fn Mouse0() { "Mouse0" }
    pub fn Mouse1() { "Mouse1" }
    pub fn Mouse2() { "Mouse2" }
}
